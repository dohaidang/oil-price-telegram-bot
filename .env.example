# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# CrudePrice API Key (optional, for additional data)
CRUDE_API_KEY=

# EIA API Key (optional, for historical data)
EIA_API_KEY=

# Price update interval in minutes
UPDATE_INTERVAL=5

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
